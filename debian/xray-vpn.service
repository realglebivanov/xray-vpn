[Unit]
Description=Xray VPN daemon
After=network-online.target
Requires=network-online.target

[Service]
Type=simple
AmbientCapabilities=CAP_NET_ADMIN
RuntimeDirectory=xray-vpn
CacheDirectory=xray-vpn
Environment="XRAY_LOCATION_ASSET=/var/cache/xray-vpn"
ExecStart=/usr/bin/xray-vpnd
PIDFile=/run/xray-vpn/xray-vpn.pid
Restart=on-failure
RestartSec=5
User=xray-vpn
Group=xray-vpn
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
