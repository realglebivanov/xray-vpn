#!/bin/sh
set -e

if ! getent group xray-vpn > /dev/null 2>&1; then
    addgroup --system xray-vpn
fi

if ! getent passwd xray-vpn > /dev/null 2>&1; then
    adduser --system --no-create-home --shell /usr/sbin/nologin \
            --ingroup xray-vpn xray-vpn
fi

echo "xray-vpn: placeholder config at /etc/xray/config.json"
echo "xray-vpn: edit with your proxy outbound, then: systemctl start xray-vpn"
echo "xray-vpn: to allow a user to control the service, run: usermod -aG xray-vpn <username>"

mkdir -p /run/xray-vpn

chown xray-vpn:xray-vpn /usr/bin/xray-vpnd
chown xray-vpn:xray-vpn /usr/bin/xray-vpn
chown -R xray-vpn:xray-vpn /etc/xray-vpn /usr/share/xray-vpn /run/xray-vpn

chmod 4550 /usr/bin/xray-vpn
chmod 500 /usr/bin/xray-vpnd
chmod 500 /usr/share/xray-vpn/geoip.dat
chmod 500 /usr/share/xray-vpn/geosite.dat
chmod 500 /etc/xray-vpn
chmod 500 /etc/xray-vpn/config.json
chmod 700 /run/xray-vpn

systemctl daemon-reload
systemctl enable xray-vpn.service || true
