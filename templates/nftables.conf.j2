#!/usr/sbin/nft -f

flush ruleset

table inet filter {
    chain input {
        type filter hook input priority filter; policy drop;
        
        # Allow loopback
        iifname "lo" counter accept
        
        # Allow established/related connections
        ct state established,related counter accept
        
        # Allow ICMP (ping)
        ip protocol icmp counter accept
        ip6 nexthdr icmpv6 counter accept

        # Navidrome
        iifname "eno1" tcp dport 4533 counter accept
        iifname "wlp4s0" tcp dport 4533 counter accept
        
        # Allow SSH from LAN only
        iifname "wlp4s0" tcp dport 22 counter accept
        
        # Allow DHCP from LAN (if running DHCP server)
        iifname "wlp4s0" udp dport 67 counter accept
        
        # Allow DNS from LAN (if running DNS server)
        iifname "wlp4s0" udp dport 53 counter accept
        iifname "wlp4s0" tcp dport 53 counter accept
        
        # Log and drop everything else
        counter log prefix "INPUT DROP: " drop
    }
    
    chain forward {
        type filter hook forward priority filter; policy drop;
       
        iifname "lo" counter accept

        # Allow xray traffic forwarding
        meta mark 0x00001337 counter accept
 
        # Allow established/related
        ct state established,related counter accept
        
        # Allow LAN to WAN
        iifname "wlp4s0" oifname "eno1" counter accept

        # Log and drop everything else
        counter log prefix "FORWARD DROP: " drop
    }
    
    chain output {
        type filter hook output priority filter; policy accept;
        counter
    }
}

table inet nat {
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        oifname "eno1" counter masquerade
    }
}
